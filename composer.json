{
    "name": "mozex/anthropic-laravel",
    "description": "Anthropic PHP for Laravel is a supercharged PHP API client that allows you to interact with the Anthropic API",
    "keywords": ["laravel", "php", "anthropic", "sdk", "claude", "Claude-3-Opus", "Claude-3-Sonnet", "Claude-3-Haiku", "api", "client", "natural", "language", "processing"],
    "license": "MIT",
    "authors": [
        {
            "name": "Mozex",
            "email": "hello@mozex.dev",
            "homepage": "https://mozex.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2.0",
        "guzzlehttp/guzzle": "^7.9.3",
        "laravel/framework": "^11.29|^12.12",
        "mozex/anthropic-php": "^v1.2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.22.0",
        "pestphp/pest": "^3.8.2|^4.0.0",
        "pestphp/pest-plugin-arch": "^3.1.1|^4.0.0",
        "phpstan/phpstan": "^2.1",
        "spatie/ray": "^1.41",
        "symfony/var-dumper": "^7.2.6"
    },
    "autoload": {
        "psr-4": {
            "Anthropic\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "COV": "0.11.0",
        "laravel": {
            "providers": [
                "Anthropic\\Laravel\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "pint -v",
        "test:lint": "pint --test -v",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
